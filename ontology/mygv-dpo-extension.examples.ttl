@prefix myg: <https://w3id.org/myglico/resource/> .
@prefix mygv: <https://w3id.org/myglico/vocab/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

myg:patient_001
    a mygv:Patient ;
    mygv:externalPatientCode "patient_001" .

myg:dataset_001
    a mygv:DataSource ;
    mygv:sourceName "Fonte de exemplo"@pt ,
        "Example source"@en .

myg:raw_record_001
    a mygv:RawRecord ;
    mygv:sourceRecordId "record_001" ;
    mygv:belongsToDataSource myg:dataset_001 .

myg:raw_record_002
    a mygv:RawRecord ;
    mygv:sourceRecordId "record_002" ;
    mygv:belongsToDataSource myg:dataset_001 .

myg:raw_record_003
    a mygv:RawRecord ;
    mygv:sourceRecordId "record_003" ;
    mygv:belongsToDataSource myg:dataset_001 .

myg:measurement_001
    a mygv:CapillaryGlucoseMeasurement ;
    mygv:belongsToPatient myg:patient_001 ;
    mygv:derivedFromRawRecord myg:raw_record_001 ;
    mygv:glucoseValueMgDl "110"^^xsd:decimal ;
    mygv:measuredAt "2026-05-03T08:00:00"^^xsd:dateTime ;
    mygv:measurementContext "Antes do café da manhã"@pt ,
        "Before breakfast"@en .

myg:measurement_002
    a mygv:CapillaryGlucoseMeasurement ;
    mygv:belongsToPatient myg:patient_001 ;
    mygv:derivedFromRawRecord myg:raw_record_002 ;
    mygv:glucoseValueMgDl "65"^^xsd:decimal ;
    mygv:measuredAt "2026-05-03T12:00:00"^^xsd:dateTime ;
    mygv:measurementContext "Antes do almoço"@pt ,
        "Before lunch"@en .

myg:measurement_003
    a mygv:CapillaryGlucoseMeasurement ;
    mygv:belongsToPatient myg:patient_001 ;
    mygv:derivedFromRawRecord myg:raw_record_003 ;
    mygv:glucoseValueMgDl "190"^^xsd:decimal ;
    mygv:measuredAt "2026-05-03T20:00:00"^^xsd:dateTime ;
    mygv:measurementContext "Após o jantar"@pt ,
        "After dinner"@en .
